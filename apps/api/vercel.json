{
    "version": 2,
    "ignoreCommand": "npx turbo-ignore --fallback=HEAD^1",
    "builds": [
        {
            "src": "dist/vercel.cjs",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["dist/**", "generated/prisma/**"]
            }
        }
    ],
    "functions": {
        "dist/vercel.cjs": {
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "dist/vercel.cjs"
        }
    ]
}