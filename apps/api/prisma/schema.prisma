// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum OrderStatus {
  pending
  confirmed
  out_for_delivery
  delivered
  cancelled
}

enum OrderPlacedBy {
  customer
  agent
}

enum WalletTransactionType {
  earned
  redeemed
  expired
  bonus_referral
  bonus_promotion
  manual_adjustment
}

enum TierName {
  Bronze
  Silver
  Gold
}

enum TierChangeReason {
  upgrade
  downgrade
  initial
}

enum PromotionType {
  double_points
  percentage_discount
  fixed_discount
  free_delivery
  bundle
}

// =============================================================================
// BETTER AUTH — DO NOT MODIFY THESE MODELS
// Managed entirely by Better Auth. Changes here will break authentication.
// =============================================================================

model User {
  id            String   @id @default(uuid()) // Better Auth manages ID generation; DB default is a fallback
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String? // avatar — Cloudflare URL
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth session & account relations
  sessions Session[]
  accounts Account[]

  // Better Auth admin plugin fields
  // role values: "customer" | "agent" | "admin" | "officer"
  role       String?   @default("customer")
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // ── Good Taste Ltd — extended user fields ─────────────
  phone    String?
  birthday DateTime? // for birthday push notifications
  fcmToken String? // latest FCM device token

  // Location (entered at registration by customer or agent)
  address String?
  city    String?
  country String?

  // Customer loyalty fields
  referralCode  String? @unique // generated on customer registration
  walletBalance Float   @default(0)
  totalSpend    Float   @default(0) // cumulative spend, drives tier logic

  // Customer → assigned agent
  assignedAgentId String?
  assignedAgent   User?   @relation("AgentCustomers", fields: [assignedAgentId], references: [id])
  customers       User[]  @relation("AgentCustomers")

  // Loyalty tier
  tierId String?
  tier   LoyaltyTier? @relation(fields: [tierId], references: [id])

  // ── Good Taste Ltd relations ──────────────────────────
  ordersAsCustomer   Order[]             @relation("CustomerOrders")
  ordersAsAgent      Order[]             @relation("AgentOrders")
  walletTransactions WalletTransaction[]
  tierHistories      TierHistory[]
  qrCodesAsAgent     QRCode[]            @relation("AgentQRCodes")
  qrCodesAsCustomer  QRCode[]            @relation("CustomerQRCodes")

  @@index([role])
  @@index([assignedAgentId])
  @@index([tierId])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // hashed — managed by Better Auth
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =============================================================================
// CATALOGUE & STOCK
// =============================================================================

model Category {
  id          String   @id @default(uuid())
  name        String   @unique // maize, feed
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products         Product[] // one-to-many
  targetPromotions PromotionTargetCategory[]

  @@map("category")
}

model Product {
  id          String  @id @default(uuid())
  name        String // breakfast, roller meal
  description String?
  isActive    Boolean @default(true)
  image       String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants ProductVariant[] // one-to-many

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@map("product")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // What makes this variant unique
  weightKg    Float // e.g. 25.0, 20.0, 12.5
  weightLabel String // e.g. "25kg", "20kg", "12.5kg"

  price     Float // e.g. 250.00
  earnValue Float // 1% of price — e.g. 2.50
  // Tip: recalculate earnValue in your API whenever price is updated

  // Variant-level images (photo of the actual 25kg bag)
  image String? // Cloudflare URLs

  // Stock management (per variant)
  stockQty          Int       @default(0)
  lowStockThreshold Int       @default(10)
  isOutOfStock      Boolean   @default(false)
  lastRestockedAt   DateTime?

  isActive Boolean @default(true)

  orderItems       OrderItem[]
  bundlePromotions PromotionBundleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, weightKg]) // can't have two 25kg variants of the same product
  @@index([productId])
  @@index([isOutOfStock])
  @@map("product_variant")
}

// =============================================================================
// ORDERS & DELIVERY
// =============================================================================

model Order {
  id String @id @default(uuid())

  customerId String
  customer   User   @relation("CustomerOrders", fields: [customerId], references: [id])

  agentId String
  agent   User   @relation("AgentOrders", fields: [agentId], references: [id])

  status   OrderStatus   @default(pending)
  placedBy OrderPlacedBy

  totalAmount    Float
  discountAmount Float   @default(0)
  finalAmount    Float
  isFreeDelivery Boolean @default(false)

  walletEarned   Float @default(0)
  walletRedeemed Float @default(0)

  deliveryAddress String?
  notes           String?

  cashConfirmedAt DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  items  OrderItem[] // one-to-many
  qrCode QRCode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("order")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  // Snapshots at time of order — never changes retroactively
  productName  String // e.g. "Breakfast"
  weightLabel  String // e.g. "25kg"
  productPrice Float // e.g. 250.00
  earnValue    Float // e.g. 2.50 (1% of price at time of order)
  quantity     Int
  subtotal     Float // productPrice × quantity
  product      Product? @relation(fields: [productId], references: [id])
  productId    String?

  @@index([orderId])
  @@map("order_item")
}

model QRCode {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  customerId String
  customer   User   @relation("CustomerQRCodes", fields: [customerId], references: [id])

  agentId String
  agent   User   @relation("AgentQRCodes", fields: [agentId], references: [id])

  code      String    @unique // UUID or signed token
  expiresAt DateTime
  isExpired Boolean   @default(false) // set by cron when expiresAt is past
  isUsed    Boolean   @default(false)
  usedAt    DateTime?

  amountToCredit Float // pre-calculated on generation

  createdAt DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
  @@map("qr_code")
}

// =============================================================================
// LOYALTY — POINTS, TIERS, REWARDS
// =============================================================================

model WalletTransaction {
  id          String                @id @default(uuid())
  customerId  String
  customer    User                  @relation(fields: [customerId], references: [id])
  type        WalletTransactionType
  amount      Float // positive = credit, negative = debit
  balance     Float // customer balance AFTER this transaction
  description String?
  orderId     String? // linked order if applicable
  expiresAt   DateTime? // set for 'earned' transactions
  isExpired   Boolean               @default(false) // set by cron when expiresAt is past
  createdAt   DateTime              @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([isExpired, expiresAt])
  @@map("wallet_transaction")
}

// Singleton — always one row with key = 'global'
model WalletConfig {
  id                    String   @id @default(uuid())
  key                   String   @unique @default("global")
  earnRatePercent       Float    @default(0.01) // 1% of purchase price
  expiryMonths          Int      @default(12)
  referralBonusReferrer Float    @default(5.00)
  referralBonusReferred Float    @default(2.50)
  updatedAt             DateTime @updatedAt

  @@map("wallet_config")
}

model LoyaltyTier {
  id             String   @id @default(uuid())
  name           TierName @unique
  minSpend       Float
  maxSpend       Float? // null for Gold (no ceiling)
  earnMultiplier Float    @default(1.0)
  color          String? // hex color for UI badge

  benefits          String[]
  users             User[]
  fromTierHistories TierHistory[]         @relation("FromTier")
  toTierHistories   TierHistory[]         @relation("ToTier")
  targetPromotions  PromotionTargetTier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loyalty_tier")
}

model TierHistory {
  id         String           @id @default(uuid())
  customerId String
  customer   User             @relation(fields: [customerId], references: [id])
  fromTierId String?
  fromTier   LoyaltyTier?     @relation("FromTier", fields: [fromTierId], references: [id])
  toTierId   String?
  toTier     LoyaltyTier?     @relation("ToTier", fields: [toTierId], references: [id], onDelete: SetNull)
  reason     TierChangeReason
  changedAt  DateTime         @default(now())

  @@index([customerId, changedAt(sort: Desc)])
  @@map("tier_history")
}

// =============================================================================
// PROMOTIONS
// =============================================================================

model Promotion {
  id          String        @id @default(uuid())
  name        String
  description String?
  type        PromotionType
  isActive    Boolean       @default(true)

  // Discount value — interpretation depends on type:
  // percentage_discount / bundle: percent off (e.g. 10 = 10%)
  // fixed_discount: flat amount off (e.g. 5.00)
  // double_points: earn multiplier (e.g. 2 = 2×)
  // free_delivery: not used
  discountValue Float?

  startsAt   DateTime
  endsAt     DateTime
  usageLimit Int? // null = unlimited
  usageCount Int      @default(0)

  targetTiers      PromotionTargetTier[]
  targetCategories PromotionTargetCategory[]
  bundleItems      PromotionBundleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@map("promotion")
}

model PromotionTargetTier {
  id          String      @id @default(uuid())
  promotionId String
  promotion   Promotion   @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tierId      String
  tier        LoyaltyTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([promotionId, tierId])
  @@map("promotion_target_tier")
}

model PromotionTargetCategory {
  id          String    @id @default(uuid())
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promotionId, categoryId])
  @@map("promotion_target_category")
}

model PromotionBundleItem {
  id          String         @id @default(uuid())
  promotionId String
  promotion   Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([promotionId, variantId])
  @@map("promotion_bundle_item")
}
