{
  "version": 2,
  "ignoreCommand": "npx turbo-ignore --fallback=HEAD^1",
  "functions": {
    "dist/vercel.cjs": {
      "runtime": "@vercel/node",
      "maxDuration": 10,
      "includeFiles": "dist/**\ngenerated/prisma/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/vercel.cjs"
    }
  ]
}