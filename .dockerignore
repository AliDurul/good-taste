# Version control
.git
.gitignore
.gitattributes

# Dependencies (rebuilt inside Docker)
**/node_modules
**/.pnpm-store
**/.cache

# Build outputs (built inside Docker)
**/.next
**/dist
**/.turbo

# Environment files (injected at runtime via compose / env_file)
**/.env
**/.env.*
!**/.env.example

# Logs
**/*.log
**/npm-debug.log*
**/pnpm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Runtime / upload data
**/uploads

# OS artefacts
**/.DS_Store
**/Thumbs.db

# Editor / IDE
**/.vscode
**/.idea

# Test outputs
**/coverage
**/.nyc_output

# Mobile app (not needed for api/web containers)
apps/mobile

# TypeScript build info
**/*.tsbuildinfo
